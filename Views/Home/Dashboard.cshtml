@{
    ViewData["Title"] = "Database Dashboard";
}


    
<h2 class="mb-4 fw-bold">Dashboard</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

<!-- 🔥 CONTROL PANEL -->
<div class="card p-4 mb-4 shadow-sm">
    <form method="post" class="row g-3 align-items-end">

        <div class="col-md-3">
            <label class="form-label">Schema</label>
            <select name="schema" class="form-select" onchange="this.form.submit()">
                <option value="">Select Schema</option>
                @foreach (var s in ViewBag.Schemas)
                {
                    <option value="@s" selected="@(s == ViewBag.SelectedSchema ? "selected" : null)">
                        @s
                    </option>
                }
            </select>
        </div>

        <div class="col-md-3">
            <label class="form-label">Table</label>
            <select name="table" class="form-select">
                <option value="">Select Table</option>
                @if (ViewBag.Tables != null)
                {
                    foreach (var t in ViewBag.Tables)
                    {
                        <option value="@t" selected="@(t == ViewBag.SelectedTable ? "selected" : null)">
                            @t
                        </option>
                    }
                }
            </select>
        </div>

        <div class="col-md-3">
            <label class="form-label">Operation</label>
            <select name="operation" class="form-select">
                <option value="">Select Operation</option>
                <option value="select" selected="@(ViewBag.Operation == "select" ? "selected" : null)">Select</option>
                <option value="insert" selected="@(ViewBag.Operation == "insert" ? "selected" : null)">Insert</option>
                <option value="update" selected="@(ViewBag.Operation == "update" ? "selected" : null)">Update</option>
                <option value="delete" selected="@(ViewBag.Operation == "delete" ? "selected" : null)">Delete</option>
            </select>
        </div>

        <div class="col-md-3">
            <button class="btn btn-dark w-100">Execute</button>
        </div>

    </form>
</div>

<!-- 🔥 INSERT -->
@if (ViewBag.Operation == "insert" && ViewBag.Columns != null)
{
    <div class="card p-4 mb-4 shadow-sm">
        <h5>Insert Data</h5>

        <form method="post" class="row g-3">
            <input type="hidden" name="schema" value="@ViewBag.SelectedSchema" />
            <input type="hidden" name="table" value="@ViewBag.SelectedTable" />
            <input type="hidden" name="operation" value="insertdata" />

            @foreach (var col in ViewBag.Columns)
            {
                <div class="col-md-4">
                    <label class="form-label">@col</label>
                    <input class="form-control" name="@col" />
                </div>
            }

            <div class="col-12 text-end">
                <button class="btn btn-success">Insert</button>
            </div>
        </form>
    </div>
}

<!-- 🔥 DELETE -->
@if (ViewBag.Operation == "delete")
{
    <div class="card p-4 mb-4 shadow-sm">
        <h5>Delete Record</h5>

        <form method="post" class="row g-3">
            <input type="hidden" name="schema" value="@ViewBag.SelectedSchema" />
            <input type="hidden" name="table" value="@ViewBag.SelectedTable" />
            <input type="hidden" name="operation" value="deletedata" />

            <div class="col-md-6">
                <label class="form-label">Enter ID</label>
                <input class="form-control" name="id" />
            </div>

            <div class="col-12 text-end">
                <button class="btn btn-danger">Delete</button>
            </div>
        </form>
    </div>
}

<!-- 🔥 UPDATE -->
@if (ViewBag.Operation == "update" && ViewBag.Columns != null)
{
    <div class="card p-4 mb-4 shadow-sm">
        <h5>Update Record</h5>

        <form method="post" class="row g-3">
            <input type="hidden" name="schema" value="@ViewBag.SelectedSchema" />
            <input type="hidden" name="table" value="@ViewBag.SelectedTable" />
            <input type="hidden" name="operation" value="updatedata" />

            <div class="col-md-3">
                <label class="form-label">ID</label>
                <input class="form-control" name="id" />
            </div>

            <div class="col-md-4">
                <label class="form-label">Column</label>
                <select name="column" class="form-select">
                    @foreach (var col in ViewBag.Columns)
                    {
                        <option value="@col">@col</option>
                    }
                </select>
            </div>

            <div class="col-md-5">
                <label class="form-label">New Value</label>
                <input class="form-control" name="value" />
            </div>

            <div class="col-12 text-end">
                <button class="btn btn-warning">Update</button>
            </div>
        </form>
    </div>
}

<!-- 🔥 TABLE -->
@if (ViewBag.Rows != null && ViewBag.Rows.Count > 0)
{
    <div class="card p-4 shadow-sm">
        <h5>Table Data</h5>

        <div class="table-responsive">
            <table class="table table-striped table-hover mt-3">

                <thead class="table-dark">
                    <tr>
                        @foreach (var col in ViewBag.Rows[0].Keys)
                        {
                            <th>@col</th>
                        }
                    </tr>
                </thead>

                <tbody>
                    @foreach (var row in ViewBag.Rows)
                    {
                        <tr>
                            @foreach (var val in row.Values)
                            {
                                <td>@val</td>
                            }
                        </tr>
                    }
                </tbody>

            </table>
        </div>
    </div>
}
else if (ViewBag.Operation == "select")
{
    <p class="text-muted">No data found</p>
}

